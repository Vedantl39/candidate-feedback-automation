# ── Database ──────────────────────────────────────────────────────────────────
# For local SQLite (default, no setup required):
DATABASE_URL=sqlite:///./candidate_feedback.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/candidate_feedback

# ── Anthropic API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Gmail API ─────────────────────────────────────────────────────────────────
# Path to your downloaded credentials.json from Google Cloud Console
GMAIL_CREDENTIALS_PATH=credentials.json
# Path where the OAuth token will be saved after first login
GMAIL_TOKEN_PATH=token.json
# The Gmail address emails will be sent from
SENDER_EMAIL=hr@yourcompany.com

# ── Email mode ────────────────────────────────────────────────────────────────
# Set to "true" to skip real email sending and print to console instead
# Useful for local development and testing
MOCK_EMAIL=true

# ── Workflow settings ─────────────────────────────────────────────────────────
# Options: manual | semi_auto | auto
WORKFLOW_MODE=manual

# ── Webhook security ──────────────────────────────────────────────────────────
# Optional secret to validate incoming ATS webhooks
WEBHOOK_SECRET=

# ── Dashboard ─────────────────────────────────────────────────────────────────
# URL of the FastAPI backend (used by Streamlit dashboard)
API_BASE_URL=http://localhost:8000
